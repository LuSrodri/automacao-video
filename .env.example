# ---- Chaves de API (obrigatórias) ----
# Chave da OpenAI (https://platform.openai.com/api-keys) — roteiro
OPENAI_API_KEY=

# Chave da xAI (https://console.x.ai) — coleta de posts (X Search) e
# busca das imagens-chave (Web Search)
XAI_API_KEY=

# Chave da ElevenLabs (https://elevenlabs.io/app/settings/api-keys) — narração
ELEVENLABS_API_KEY=

# Chave do Firecrawl (https://firecrawl.dev) — busca das imagens-chave
# (Search API com sources=["images"]) e das notícias (sources=["news"]).
FIRECRAWL_API_KEY=

# ---- Fontes ----
# Opcional. Vazio = busca aberta pelas threads de tech/AI mais discutidas
# do dia. Para restringir a contas específicas, liste-as separadas por
# vírgula (sem @, máximo 20), ex.: OpenAI,xai,AnthropicAI,GoogleDeepMind
X_ACCOUNTS=

# Janela de coleta em horas (posts mais recentes que isso)
JANELA_HORAS=24

# Quantas trends mais faladas do X coletar para escolher a do vídeo
NUM_TRENDS=10
# Quantas notícias (Firecrawl news) buscar para enriquecer a trend escolhida
NUM_NOTICIAS=6

# ---- Modelos (opcionais, valores padrão abaixo) ----
TEXT_MODEL=gpt-5.4-mini
# Modelo da xAI que executa as buscas (posts e imagens)
SEARCH_MODEL=grok-4.3

# ---- Narração (ElevenLabs) ----
ELEVENLABS_VOICE_ID=czvzJwIVS2asEKnthV40
# Voz usada quando rodar com -usa (público americano)
ELEVENLABS_VOICE_ID_USA=POPWFdpTM8Mn2ZQEagyQ
# eleven_v3 suporta audio tags ([excited], [whispers] etc.) no roteiro
ELEVENLABS_MODEL=eleven_v3

# ---- Vídeo ----
# Duração-alvo da narração em segundos; a duração final do vídeo segue o áudio
VIDEO_DURACAO=60
# Resolução do vídeo. Padrão: vertical 9:16 para shorts/reels.
VIDEO_LARGURA=1080
VIDEO_ALTURA=1920

# ---- YouTube (publicação automática via Data API v3) ----
# Credenciais OAuth (Google Cloud Console > Credentials > OAuth client ID,
# tipo "Desktop app"). A publicação roda sempre, independente da flag -usa.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Canal português — gerado uma vez com: python main.py --auth-youtube
YOUTUBE_REFRESH_TOKEN=
# Canal inglês (-usa) — gerado com: python main.py --auth-youtube-usa
YOUTUBE_REFRESH_TOKEN_USA=
# public | unlisted | private
YOUTUBE_PRIVACY=public
# Categoria do YouTube (28 = Science & Technology)
YOUTUBE_CATEGORY_ID=28
# Nome de usuário exibido sob o logo do Shorts, no topo do vídeo (com ou
# sem @). Canal português:
YOUTUBE_HANDLE=
# Canal inglês (-usa):
YOUTUBE_HANDLE_USA=

# X API oficial (opcional; pay-per-use, ~US$ 0,005 por post/mídia lida).
# Consumer Key + Secret do app em https://developer.x.com — usados para baixar
# as fotos e vídeos dos posts originais da trend. Vazios = etapa pulada.
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
