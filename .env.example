# ---- Chaves de API (obrigatórias) ----
# Chave da OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Chave da xAI (https://console.x.ai) — usada na coleta de posts (X Search)
# e na geração do vídeo (Grok Imagine)
XAI_API_KEY=

# ---- Fontes ----
# Opcional. Vazio = busca aberta pelas threads de tech/AI mais discutidas
# do dia. Para restringir a contas específicas, liste-as separadas por
# vírgula (sem @, máximo 20), ex.: OpenAI,xai,AnthropicAI,GoogleDeepMind
X_ACCOUNTS=

# Janela de coleta em horas (posts mais recentes que isso)
JANELA_HORAS=24

# ---- Modelos (opcionais, valores padrão abaixo) ----
TEXT_MODEL=gpt-5.4-mini
# Modelo da xAI que executa a busca de posts no X
SEARCH_MODEL=grok-4.3
# Atenção: gpt-image-2 NÃO suporta fundo transparente na API.
# Para imagens com transparência garantida, use gpt-image-1.5.
IMAGE_MODEL=gpt-image-1.5
# Qualidade das imagens-chave: low (~US$ 0,01/img), medium (~US$ 0,04),
# high (~US$ 0,17) ou auto
IMAGE_QUALITY=low
# grok-imagine-video-1.5-preview (mais novo, US$ 0,08/seg em 480p) ou
# grok-imagine-video (estável, US$ 0,05/seg em 480p)
VIDEO_MODEL=grok-imagine-video-1.5-preview

# ---- Vídeo ----
# Duração em segundos (1 a 25). Acima de 10s o pipeline gera segmentos de
# até 10s em paralelo (cada um narrando uma parte do texto) e junta com ffmpeg.
VIDEO_DURACAO=20
# 480p ou 720p (720p custa mais por segundo)
VIDEO_RESOLUCAO=480p
# Proporção: 9:16 (vertical), 16:9, 1:1, 4:3, 3:4, 3:2 ou 2:3.
# Dica: use um clipe.png já na mesma proporção para evitar distorção.
VIDEO_ASPECT_RATIO=9:16
